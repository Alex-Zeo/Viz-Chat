{
  "name": "control-room",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch --env-file .env server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file .env server/index.ts",
    "seed": "tsx data/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "start": "tsx --env-file .env server/index.ts",
    "generate-logo": "tsx scripts/generate-logo.ts"
  },
  "dependencies": {
    "@a2ui/react": "^0.9.1",
    "@a2ui/web_core": "^0.9.2",
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@ag-ui/encoder": "^0.0.53",
    "@anthropic-ai/claude-code": "^2.1.138",
    "@anthropic-ai/sdk": "^0.57.0",
    "@copilotkit/react-core": "^1.57.1",
    "@copilotkit/react-textarea": "1.57.1",
    "@copilotkit/react-ui": "^1.57.1",
    "@copilotkit/runtime": "^1.57.1",
    "@google/genai": "^1.51.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "express": "^5.0.0",
    "puppeteer-core": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "uuid": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
